# Copy this file to .env and fill in your values.
# .env is loaded automatically by the Clarity Engine CLI.

# Required: your Anthropic API key
CLAUDE_API_KEY=your_anthropic_api_key_here

# Optional: Anthropic model to use (overridden by the --model CLI flag).
# Both claude-sonnet-4-6 and claude-opus-4-6 are supported.
CLARITY_MODEL=claude-sonnet-4-6
